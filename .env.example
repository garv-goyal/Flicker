# Flicker — environment variables. Copy to `.env` and fill in. Never commit `.env`.

# --- TMDB (themoviedb.org → Settings → API) ---
TMDB_API_KEY=
TMDB_API_READ_ACCESS_TOKEN=

# --- OMDb (omdbapi.com → free tier key) ---
OMDB_API_KEY=

# --- YouTube Data API v3 (Google Cloud Console) ---
YOUTUBE_API_KEY=

# --- Reddit (reddit.com/prefs/apps → script app) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=flicker:v1.0 (by /u/yourusername)

# --- Warehouse: DuckDB (local, default — no account, no card) ---
# Leave as-is to use the local flicker.duckdb file for all dev.
FLICKER_USE_MOTHERDUCK=false
# FLICKER_DB_PATH=/custom/path/flicker.duckdb   # optional override

# --- MotherDuck (free cloud tier, no card — only for the live dashboard) ---
# Sign up at motherduck.com, create a token, then set the two lines below and
# flip FLICKER_USE_MOTHERDUCK=true when you want to read/write the cloud copy.
MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=flicker

# --- Postgres (local Docker, watched by Debezium) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=flicker_ops
POSTGRES_USER=flicker
POSTGRES_PASSWORD=flicker

# --- Gemini (Text-to-SQL chat page — Google AI Studio, free tier) ---
GEMINI_API_KEY=
